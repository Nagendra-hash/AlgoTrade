# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:trader123@localhost:5432/tradeai
DATABASE_SYNC_URL=postgresql://trader:trader123@localhost:5432/tradeai

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security (generate strong values for production) ──────────
SECRET_KEY=change-this-secret-key-in-production-32chars
JWT_SECRET_KEY=change-this-jwt-secret-in-production-32chars

# ── AI APIs (at least one required for AI sentiment) ──────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here

# ── News APIs (optional - RSS feeds work without these) ───────
NEWSAPI_KEY=your-newsapi-key
FINNHUB_KEY=your-finnhub-key

# ── Broker APIs (optional - paper trading works without) ──────
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# ── Alerts ────────────────────────────────────────────────────
ALERT_CHECK_INTERVAL_SECONDS=15
SENTIMENT_CACHE_MINUTES=15
NEWS_CACHE_MINUTES=5
MAX_ALERTS_PER_USER=50

# ── Notifications (optional) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@tradeai.com

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3001","http://localhost:3000"]

# ── Tuning ────────────────────────────────────────────────────
DEBUG=true
